#!/bin/sh
# Maven Wrapper script for Unix

# Resolve project base directory
BASEDIR="$(dirname "$0")"
MAVEN_PROJECTBASEDIR="${MAVEN_PROJECTBASEDIR:-${BASEDIR}}"

# Add default JVM options here
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

# Maven wrapper jar name
WRAPPER_JAR="maven-wrapper.jar"
WRAPPER_LAUNCHER="org.apache.maven.wrapper.MavenWrapperMain"

# Check for maven-wrapper.jar
if [ ! -f "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/$WRAPPER_JAR" ]; then
    echo "Downloading Maven Wrapper JAR..."
    WRAPPER_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar"
    if command -v curl > /dev/null; then
        curl -sL "$WRAPPER_URL" -o "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/$WRAPPER_JAR"
    elif command -v wget > /dev/null; then
        wget -q "$WRAPPER_URL" -O "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/$WRAPPER_JAR"
    else
        echo "Error: curl or wget not found. Please install one of them."
        exit 1
    fi
fi

# Execute Maven
exec java ${DEFAULT_JVM_OPTS} -classpath "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/$WRAPPER_JAR" \
    "$WRAPPER_LAUNCHER" "$@"
